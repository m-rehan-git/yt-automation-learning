# ============================================================
#  YouTube Automation Agent — Environment Configuration
# ============================================================

# --- AI (Required) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Stock Footage (Required) ---
PEXELS_API_KEY=your_pexels_api_key_here

# --- YouTube Upload (Optional — skip with --no-upload) ---
# Download client_secrets.json from Google Cloud Console
# (YouTube Data API v3 → OAuth 2.0 → Desktop App)
# Save it as: config/client_secrets.json

# --- TTS Voice ---
# Options: en-US-GuyNeural | en-US-JennyNeural | en-GB-RyanNeural | en-AU-WilliamNeural
TTS_VOICE=en-US-GuyNeural

# --- Video Settings ---
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30

# --- Channel Settings ---
CHANNEL_NICHE=Mystery and History
YOUTUBE_PRIVACY_STATUS=private

# --- Output ---
OUTPUT_DIR=output